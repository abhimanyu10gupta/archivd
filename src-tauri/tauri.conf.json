{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Archivd",
  "version": "0.1.0",
  "identifier": "com.archivd.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popup",
        "title": "Archivd",
        "width": 380,
        "height": 420,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Archivd Settings",
        "width": 480,
        "height": 360,
        "resizable": false,
        "decorations": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
